APP_ENV=dev
APP_NAME=Secure AI Audit Assistant
API_HOST=0.0.0.0
API_PORT=8080
CORS_ORIGINS=http://localhost:5173

JWT_ISSUER=secure-ai-audit-assistant
JWT_AUDIENCE=secure-ai-audit
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800
JWT_SIGNING_KEY=change-me-super-secret
PASSWORD_BCRYPT_ROUNDS=12

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=secure_audit
POSTGRES_USER=secure
POSTGRES_PASSWORD=secure
DATABASE_URL=postgresql+asyncpg://secure:secure@postgres:5432/secure_audit

NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4jpassword
RBAC_CACHE_TTL_SECONDS=30

CHROMA_HTTP_URL=http://chromadb:8000
CHROMA_COLLECTION=doc_chunks
EMBEDDING_DIM=384
RAG_TOP_K=8
RAG_KEYWORD_TOP_K=12
HYBRID_ALPHA=0.65

MOCK_MODE=true
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=local-dev
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
LLM_REQUEST_TIMEOUT_SECONDS=30

DOC_STORAGE_DIR=/data/documents

MAX_QUERY_CHARS=512
MAX_UPLOAD_BYTES=5242880
